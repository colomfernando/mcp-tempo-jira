{
	"name": "mcp-tempo-jira",
	"version": "1.0.0",
	"description": "MCP server for Tempo time tracking plugin and Jira",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"mcp-tempo-jira": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc",
		"dev": "tsc --watch",
		"start": "pnpm build && node --env-file=.env dist/index.js"
	},
